execute unless entity @e[type=minecraft:interaction,tag=sws.clickable,distance=..4,sort=nearest,limit=1] run tellraw @s {"text":"[Simple Waystone] No nearby waystone found.","color":"red"}
execute if entity @e[type=minecraft:interaction,tag=sws.clickable,distance=..4,sort=nearest,limit=1] if data entity @s SelectedItem.components."minecraft:custom_name" run data modify storage simple_waystone:rename name set from entity @s SelectedItem.components."minecraft:custom_name"
execute if entity @e[type=minecraft:interaction,tag=sws.clickable,distance=..4,sort=nearest,limit=1] unless data entity @s SelectedItem.components."minecraft:custom_name" if data entity @s SelectedItem.components."minecraft:item_name" run data modify storage simple_waystone:rename name set from entity @s SelectedItem.components."minecraft:item_name"
execute if entity @e[type=minecraft:interaction,tag=sws.clickable,distance=..4,sort=nearest,limit=1] if data entity @s SelectedItem.components."minecraft:custom_name" run function simple_waystone:rename/apply_nearest
